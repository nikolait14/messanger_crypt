# App
APP_ENV=local
LOG_LEVEL=debug

# Gateway
GATEWAY_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s

# gRPC services
AUTH_GRPC_PORT=9001
AUTH_GRPC_ADDR=auth:9001
USER_GRPC_PORT=9002
USER_GRPC_ADDR=user:9002
MESSAGE_GRPC_PORT=9003
MESSAGE_GRPC_ADDR=message:9003

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=messenger
POSTGRES_USER=messenger
POSTGRES_PASSWORD=messenger
DATABASE_URL=postgres://messenger:messenger@postgres:5432/messenger?sslmode=disable

# Security
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
ACCESS_TOKEN_TTL=60m
REFRESH_TOKEN_TTL=720h

# Encryption (32-byte key for AES-256)
# Example: 0123456789abcdef0123456789abcdef
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
